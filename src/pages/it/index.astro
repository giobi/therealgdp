---
import Base from '@/layouts/Base.astro';
import Icon from '@/components/Icons.astro';
import { t } from '@/i18n';
import countries from '@/data/countries.json';

const locale = 'it';
const ranked = countries
  .map(c => ({
    ...c,
    realGdp: Math.round((c.physical + c.human + c.natural + c.institutions + c.technology) / 5 * 10) / 10
  }))
  .sort((a, b) => b.realGdp - a.realGdp);

const dims = ['physical', 'human', 'natural', 'institutions', 'technology'] as const;
const dimColors = { physical: 'blue', human: 'green', natural: 'amber', institutions: 'accent-light', technology: 'red' };
const dimLabels = {
  physical: t(locale, 'home.col_physical'),
  human: t(locale, 'home.col_human'),
  natural: t(locale, 'home.col_natural'),
  institutions: t(locale, 'home.col_institutions'),
  technology: t(locale, 'home.col_technology'),
};
const slideshowLabels = {
  physical: t(locale, 'home.slideshow_physical'),
  human: t(locale, 'home.slideshow_human'),
  natural: t(locale, 'home.slideshow_natural'),
  institutions: t(locale, 'home.slideshow_institutions'),
  technology: t(locale, 'home.slideshow_technology'),
};
const topByDim = Object.fromEntries(
  dims.map(d => [d, [...countries].sort((a, b) => (b as any)[d] - (a as any)[d]).slice(0, 5)])
);

const maxGdp = Math.max(...countries.map(c => c.gdp_per_capita_ppp));
const minGdp = Math.min(...countries.map(c => c.gdp_per_capita_ppp));
// Normalize GDP to 0-100 scale, compute gap (rGDP - GDP_norm)
// Positive gap = "richer than GDP says", Negative = "GDP inflated vs real wealth"
const rankedWithGap = ranked.map(c => {
  const gdpNorm = Math.round((c.gdp_per_capita_ppp - minGdp) / (maxGdp - minGdp) * 1000) / 10;
  const gap = Math.round((c.realGdp - gdpNorm) * 10) / 10;
  return { ...c, gdpNorm, gap };
});
---

<Base title={t(locale, 'home.hero_title')} locale={locale}>

  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/8 via-transparent to-teal/5 pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-20 pb-14 relative text-center">
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-black tracking-tighter leading-[1.05] mb-6">
        The <span class="text-accent-light">Real</span> GDP
      </h1>
      <p class="text-text-secondary text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed mb-10">
        {t(locale, 'home.hero_sub')}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#rankings" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent hover:bg-accent/90 text-white font-bold rounded-xl text-lg transition-colors">
          {t(locale, 'home.hero_cta_data')} <span class="text-xl">&darr;</span>
        </a>
        <a href={`/${locale}/explain`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-card hover:bg-surface border border-border text-text-secondary font-bold rounded-xl text-lg transition-colors">
          {t(locale, 'home.hero_cta_explain')}
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ TWO CARDS SIDE BY SIDE ═══ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16">
    <div class="grid md:grid-cols-2 gap-6 items-stretch">

      <!-- LEFT CARD: Dimension explainer slideshow -->
      <div class="bg-surface border border-border rounded-2xl p-6 sm:p-8 flex flex-col" id="dim-explainer">
        <h2 class="text-lg font-bold mb-1">{t(locale, 'home.dimensions_title')}</h2>
        <p class="text-text-muted text-sm mb-6">{t(locale, 'home.dimensions_sub')}</p>

        <div class="flex-1 relative">
          {dims.map((d, idx) => (
            <div class={`dim-explain-slide ${idx === 0 ? '' : 'hidden'}`} data-dim={d}>
              <div class="flex items-center gap-3 mb-3">
                <div class={`w-10 h-10 rounded-xl bg-${dimColors[d]}/15 flex items-center justify-center shrink-0`}>
                  <Icon name={d} size={22} class={`text-${dimColors[d]}`} />
                </div>
                <span class={`text-lg font-bold text-${dimColors[d]}`}>{dimLabels[d]}</span>
              </div>
              <p class="text-text-secondary text-sm leading-relaxed">
                {t(locale, `home.dim_${d}_desc`)}
              </p>
            </div>
          ))}
        </div>

        <!-- Dimension dots (always at bottom) -->
        <div class="flex justify-center gap-1.5 mt-6 pt-4 border-t border-border/50" id="dim-explain-dots">
          {dims.map((d, idx) => (
            <button data-idx={idx} data-dim={d}
              class={`w-8 h-8 rounded-lg flex items-center justify-center transition-colors ${idx === 0 ? `bg-${dimColors[d]}/20` : 'bg-card hover:bg-card/80'}`}>
              <Icon name={d} size={16} class={idx === 0 ? `text-${dimColors[d]}` : 'text-text-muted'} />
            </button>
          ))}
        </div>
      </div>

      <!-- RIGHT CARD: Mini-rankings slideshow (synced) -->
      <div class="bg-surface border border-border rounded-2xl p-6 sm:p-8 flex flex-col" id="dim-rankings">
        <h2 class="text-lg font-bold mb-4">{t(locale, 'home.slideshow_title')}</h2>

        <div class="flex-1 relative">
          {dims.map((d, idx) => (
            <div class={`dim-rank-slide ${idx === 0 ? '' : 'hidden'}`} data-dim={d}>
              <div class={`flex items-center gap-2 mb-3 text-sm font-bold text-${dimColors[d]}`}>
                <Icon name={d} size={18} class={`text-${dimColors[d]}`} />
                {slideshowLabels[d]}
              </div>
              <div class="space-y-2">
                {(topByDim as any)[d].map((c: any, rank: number) => (
                  <a href={`/${locale}/country/${c.code.toLowerCase()}`}
                     class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-card/80 transition-colors group">
                    <span class="text-text-muted font-mono text-xs w-5 text-right">{rank + 1}</span>
                    <img src={`https://flagcdn.com/w40/${c.code.toLowerCase()}.png`}
                         srcset={`https://flagcdn.com/w80/${c.code.toLowerCase()}.png 2x`}
                         width="22" height="16" alt={c.code}
                         class="rounded-sm shadow-sm" loading="lazy" />
                    <span class="font-semibold text-sm group-hover:text-accent-light transition-colors flex-1 truncate">
                      {c.name_it}
                    </span>
                    <div class="flex items-center gap-2 w-28">
                      <div class="flex-1 h-2 bg-border rounded-full overflow-hidden">
                        <div class={`h-full bg-${dimColors[d]} rounded-full`} style={`width: ${(c as any)[d]}%`}></div>
                      </div>
                      <span class={`font-bold tabular-nums text-xs text-${dimColors[d]}`}>{(c as any)[d]}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Synced dots (always at bottom) -->
        <div class="flex justify-center gap-1.5 mt-6 pt-4 border-t border-border/50" id="dim-rank-dots">
          {dims.map((d, idx) => (
            <button data-idx={idx} data-dim={d}
              class={`w-8 h-8 rounded-lg flex items-center justify-center transition-colors ${idx === 0 ? `bg-${dimColors[d]}/20` : 'bg-card hover:bg-card/80'}`}>
              <Icon name={d} size={16} class={idx === 0 ? `text-${dimColors[d]}` : 'text-text-muted'} />
            </button>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ RANKINGS TABLE ═══ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16" id="rankings">
    <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-6 gap-4">
      <div>
        <h2 class="text-2xl font-black tracking-tight">{t(locale, 'home.ranking_title')}</h2>
        <p class="text-text-muted text-sm mt-1 max-w-lg">{t(locale, 'home.ranking_sub')}</p>
      </div>
      <div class="flex gap-1 text-xs font-semibold flex-wrap" id="region-filters">
        <button data-region="all" class="px-3 py-1.5 rounded-full bg-accent/15 text-accent-light border border-accent/30">All</button>
        <button data-region="europe" class="px-3 py-1.5 rounded-full bg-card text-text-muted border border-border hover:border-accent/30">Europe</button>
        <button data-region="americas" class="px-3 py-1.5 rounded-full bg-card text-text-muted border border-border hover:border-accent/30">Americas</button>
        <button data-region="asia" class="px-3 py-1.5 rounded-full bg-card text-text-muted border border-border hover:border-accent/30">Asia</button>
        <button data-region="africa" class="px-3 py-1.5 rounded-full bg-card text-text-muted border border-border hover:border-accent/30">Africa</button>
      </div>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap gap-4 mb-4 text-xs">
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-blue"></span> Physical</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-green"></span> Human</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-amber"></span> Natural</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-accent-light"></span> Institutions</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-red"></span> Technology</span>
      <span class="flex items-center gap-1.5 ml-4"><span class="w-3 h-3 rounded-sm bg-white/90"></span> GDP/cap (PPP)</span>
    </div>

    <!-- Sort controls -->
    <div class="flex flex-wrap gap-1.5 mb-4 text-xs" id="sort-controls">
      <span class="text-text-muted py-1 mr-1">Sort by:</span>
      <button data-sort="rgdp" class="sort-btn px-2.5 py-1 rounded-full bg-accent/15 text-accent-light border border-accent/30">rGDP</button>
      <button data-sort="gdp" class="sort-btn px-2.5 py-1 rounded-full bg-card text-text-muted border border-border hover:border-accent/30">GDP/cap</button>
      <button data-sort="absgap" class="sort-btn px-2.5 py-1 rounded-full bg-card text-text-muted border border-border hover:border-teal/30 hover:text-teal">Gap rGDP vs GDP</button>
      <button data-sort="physical" class="sort-btn px-2.5 py-1 rounded-full bg-card text-text-muted border border-border hover:border-blue/30 hover:text-blue">Physical</button>
      <button data-sort="human" class="sort-btn px-2.5 py-1 rounded-full bg-card text-text-muted border border-border hover:border-green/30 hover:text-green">Human</button>
      <button data-sort="natural" class="sort-btn px-2.5 py-1 rounded-full bg-card text-text-muted border border-border hover:border-amber/30 hover:text-amber">Natural</button>
      <button data-sort="institutions" class="sort-btn px-2.5 py-1 rounded-full bg-card text-text-muted border border-border hover:border-accent-light/30 hover:text-accent-light">Institutions</button>
      <button data-sort="technology" class="sort-btn px-2.5 py-1 rounded-full bg-card text-text-muted border border-border hover:border-red/30 hover:text-red">Technology</button>
    </div>

    <div class="bg-surface border border-border rounded-xl overflow-hidden">
      {rankedWithGap.map((c, i) => {
        const total = c.physical + c.human + c.natural + c.institutions + c.technology;
        const maxTotal = 500;
        const barWidth = (total / maxTotal) * 100;
        const gdpWidth = (c.gdp_per_capita_ppp / maxGdp) * 100;
        const pPhys = (c.physical / total) * 100;
        const pHum = (c.human / total) * 100;
        const pNat = (c.natural / total) * 100;
        const pInst = (c.institutions / total) * 100;
        const pTech = (c.technology / total) * 100;
        return (
          <a href={`/${locale}/country/${c.code.toLowerCase()}`}
             class="country-row flex items-center gap-3 px-4 py-3 border-b border-border/50 hover:bg-card/50 transition-colors group"
             data-region={c.region} data-rgdp={c.realGdp} data-gdp={c.gdp_per_capita_ppp}
             data-physical={c.physical} data-human={c.human} data-natural={c.natural}
             data-institutions={c.institutions} data-technology={c.technology} data-gap={c.gap} data-absgap={Math.abs(c.gap)}>
            <span class="rank-cell text-text-muted font-mono text-xs w-6 text-right shrink-0">{i + 1}</span>
            <div class="flex items-center gap-2.5 w-36 sm:w-44 shrink-0">
              <img src={`https://flagcdn.com/w40/${c.code.toLowerCase()}.png`}
                   srcset={`https://flagcdn.com/w80/${c.code.toLowerCase()}.png 2x`}
                   width="20" height="15" alt={c.code}
                   class="rounded-sm shadow-sm" loading="lazy" />
              <span class="font-semibold text-sm group-hover:text-accent-light transition-colors truncate">{c.name_it}</span>
            </div>
            <span class="font-black text-accent-light tabular-nums text-sm w-10 text-right shrink-0">{c.realGdp}</span>
            <div class="flex-1 min-w-0 flex flex-col gap-1.5">
              <!-- Stacked Real GDP bar -->
              <div class="h-4 rounded-full overflow-hidden flex" style={`width: ${barWidth}%`}
                   title={`Physical ${c.physical} | Human ${c.human} | Natural ${c.natural} | Institutions ${c.institutions} | Technology ${c.technology}`}>
                <div class="bg-blue h-full" style={`width: ${pPhys}%`}></div>
                <div class="bg-green h-full" style={`width: ${pHum}%`}></div>
                <div class="bg-amber h-full" style={`width: ${pNat}%`}></div>
                <div class="bg-accent-light h-full" style={`width: ${pInst}%`}></div>
                <div class="bg-red h-full" style={`width: ${pTech}%`}></div>
              </div>
              <!-- GDP bar (white 90%) -->
              <div class="h-2 rounded-full overflow-hidden" title={`GDP/cap PPP: $${(c.gdp_per_capita_ppp / 1000).toFixed(1)}k`}>
                <div class="h-full bg-white/90 rounded-full" style={`width: ${gdpWidth}%`}></div>
              </div>
            </div>
            <span class="text-text-secondary tabular-nums text-xs w-14 text-right shrink-0 hidden sm:block">
              ${(c.gdp_per_capita_ppp / 1000).toFixed(1)}k
            </span>
            <span class={`tabular-nums text-xs w-12 text-right shrink-0 hidden md:block font-semibold ${c.gap > 0 ? 'text-green' : c.gap < -5 ? 'text-red' : 'text-text-muted'}`}
                  title={`Gap: rGDP ${c.realGdp} vs GDP normalized ${c.gdpNorm}. ${c.gap > 0 ? 'Richer than GDP suggests' : 'GDP overstates real wealth'}`}>
              {c.gap > 0 ? '+' : ''}{c.gap}
            </span>
          </a>
        );
      })}
    </div>
    <p class="text-text-muted text-xs mt-4 text-center">
      Data: World Bank, UNDP, WIPO. Scores 0-100. <a href={`/${locale}/methodology`} class="text-accent-light hover:underline">Methodology</a>
    </p>
  </section>

  <!-- ═══ SCRIPTS ═══ -->
  <script is:inline>
    // Sort
    document.getElementById('sort-controls')?.addEventListener('click', (e) => {
      const btn = e.target.closest('.sort-btn');
      if (!btn) return;
      const key = btn.dataset.sort;
      const container = document.querySelector('#rankings .bg-surface');
      const rows = [...container.querySelectorAll('.country-row')];
      rows.sort((a, b) => parseFloat(b.dataset[key]) - parseFloat(a.dataset[key]));
      rows.forEach((r, i) => {
        container.appendChild(r);
        if (r.style.display !== 'none') {
          r.querySelector('.rank-cell').textContent = i + 1;
        }
      });
      // Re-rank visible rows
      let rank = 0;
      rows.forEach(r => {
        if (r.style.display !== 'none') { rank++; r.querySelector('.rank-cell').textContent = rank; }
      });
      // Update button styles
      container.closest('section').querySelectorAll('.sort-btn').forEach(b => {
        b.className = b === btn
          ? 'sort-btn px-2.5 py-1 rounded-full bg-accent/15 text-accent-light border border-accent/30'
          : 'sort-btn px-2.5 py-1 rounded-full bg-card text-text-muted border border-border hover:border-accent/30';
      });
    });

    // Region filter
    document.getElementById('region-filters')?.addEventListener('click', (e) => {
      const btn = e.target.closest('button');
      if (!btn) return;
      const region = btn.dataset.region;
      document.querySelectorAll('#region-filters button').forEach(b => {
        b.className = b === btn
          ? 'px-3 py-1.5 rounded-full bg-accent/15 text-accent-light border border-accent/30'
          : 'px-3 py-1.5 rounded-full bg-card text-text-muted border border-border hover:border-accent/30';
      });
      let rank = 0;
      document.querySelectorAll('.country-row').forEach(row => {
        const show = region === 'all' || row.dataset.region === region;
        row.style.display = show ? '' : 'none';
        if (show) { rank++; row.querySelector('.rank-cell').textContent = rank; }
      });
    });

    // Synced dual-slideshow
    (function() {
      const explainSlides = document.querySelectorAll('.dim-explain-slide');
      const rankSlides = document.querySelectorAll('.dim-rank-slide');
      const explainDots = document.querySelectorAll('#dim-explain-dots button');
      const rankDots = document.querySelectorAll('#dim-rank-dots button');
      if (!explainSlides.length) return;

      const dimColorMap = {
        physical: 'blue', human: 'green', natural: 'amber',
        institutions: 'accent-light', technology: 'red'
      };

      let current = 0;

      function show(idx) {
        explainSlides.forEach((s, i) => s.classList.toggle('hidden', i !== idx));
        rankSlides.forEach((s, i) => s.classList.toggle('hidden', i !== idx));

        [explainDots, rankDots].forEach(dots => {
          dots.forEach((d, i) => {
            const btnDim = d.dataset.dim;
            const btnColor = dimColorMap[btnDim] || 'accent-light';
            if (i === idx) {
              d.className = `w-8 h-8 rounded-lg flex items-center justify-center transition-colors bg-${btnColor}/20`;
              d.querySelector('svg')?.setAttribute('class', `text-${btnColor}`);
            } else {
              d.className = 'w-8 h-8 rounded-lg flex items-center justify-center transition-colors bg-card hover:bg-card/80';
              d.querySelector('svg')?.setAttribute('class', 'text-text-muted');
            }
          });
        });
        current = idx;
      }

      function handleDotClick(e) {
        const btn = e.target.closest('button');
        if (!btn || !btn.dataset.idx) return;
        show(parseInt(btn.dataset.idx));
      }

      document.getElementById('dim-explain-dots')?.addEventListener('click', handleDotClick);
      document.getElementById('dim-rank-dots')?.addEventListener('click', handleDotClick);
    })();
  </script>
</Base>
