---
// Lucide-style SVG icons for the 5 dimensions + utility icons
// All icons are 24x24 viewBox, stroke-based

interface Props {
  name: string;
  class?: string;
  size?: number;
}

const { name, class: className = '', size = 24 } = Astro.props;

const icons: Record<string, string> = {
  // Physical Capital - building
  physical: '<path d="M3 21h18M9 8h1M9 12h1M9 16h1M14 8h1M14 12h1M14 16h1M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  
  // Human Capital - graduation cap
  human: '<path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M6 12v5c0 1.66 2.69 3 6 3s6-1.34 6-3v-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  
  // Natural Capital - leaf/tree
  natural: '<path d="M17 8c.7-1 1-2.2 1-3.5C18 2.5 16.6 1 12 1S6 2.5 6 4.5C6 5.8 6.3 7 7 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M12 1v22M7 8a9 9 0 0 0 10 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M7.5 14.5c1.5 1 3 1.5 4.5 1.5s3-.5 4.5-1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',

  // Institutions - scale of justice
  institutions: '<path d="M12 3v19M5 8l7-5 7 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M5 8l-2 8c0 1.1 1.8 2 4 2s4-.9 4-2l-2-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M19 8l-2 8c0 1.1 1.8 2 4 2s4-.9 4-2l-2-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M8 22h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>',
  
  // Technology - cpu/chip
  technology: '<rect x="4" y="4" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>',

  // Arrow left
  'arrow-left': '<path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  class={className}
  set:html={icons[name] || ''}
/>
